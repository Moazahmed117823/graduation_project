{
  "version": 2,
  "builds": [
    {
      "src": "src/main.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb"
      }
    },
    {
      "src": "src/frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/health",
      "dest": "src/main.py"
    },
    {
      "src": "/predict",
      "dest": "src/main.py"
    },
    {
      "src": "/(.*)",
      "dest": "src/frontend/$1"
    }
  ]
}
