{
  "version": 2,
  "builds": [
    {
      "src": "src/main.py",
      "use": "@vercel/python"
    },
    {
      "src": "src/frontend/index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/health",
      "dest": "src/main.py"
    },
    {
      "src": "/predict",
      "dest": "src/main.py"
    },
    {
      "src": "/(.*)",
      "dest": "src/frontend/index.html"
    }
  ]
}
